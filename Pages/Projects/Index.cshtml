@page
@model SaasAsaasApp.Pages.Projects.IndexModel
@using SaasAsaasApp.Data.Enums
@{
    ViewData["Title"] = "Projects";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-briefcase-fill me-2"></i>Projects</h2>
    <a asp-page="./Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i> Create New Project
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Title</th>
                        <th>Customer</th>
                        <th>Estimated Value</th>
                        <th>Start Date</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Projects.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                No projects found. Click "Create New" to start.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var project in Model.Projects)
                        {
                            <tr>
                                <td class="fw-bold">@project.Title</td>
                                <td>@(project.Customer?.Name ?? "N/A")</td>
                                <td>@project.EstimatedValue.ToString("C")</td>
                                <td>@(project.StartDate?.ToLocalTime().ToString("d") ?? "N/A")</td>
                                <td>
                                    @switch (project.Status)
                                    {
                                        case ProjectStatus.Active:
                                            <span class="badge bg-success">Active</span>
                                            break;
                                        case ProjectStatus.Paused:
                                            <span class="badge bg-warning text-dark">Paused</span>
                                            break;
                                        case ProjectStatus.Completed:
                                            <span class="badge bg-info text-dark">Completed</span>
                                            break;
                                        case ProjectStatus.Canceled:
                                            <span class="badge bg-danger">Canceled</span>
                                            break;
                                        default:
                                            <span class="badge bg-secondary">@project.Status</span>
                                            break;
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm">
                                        <a asp-page="./Edit" asp-route-id="@project.Id" class="btn btn-outline-secondary">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form method="post" asp-page-handler="Delete" asp-route-id="@project.Id" 
                                              onsubmit="return confirm('Are you sure you want to delete this project?');" 
                                              style="display:inline;">
                                            <button type="submit" class="btn btn-outline-danger">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
}
