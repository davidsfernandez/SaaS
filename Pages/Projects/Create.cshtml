@page
@model SaasAsaasApp.Pages.Projects.CreateModel
@using SaasAsaasApp.Data.Enums
@{
    ViewData["Title"] = "Create Project";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2><i class="bi bi-plus-circle-fill me-2"></i>Create New Project</h2>
            <a asp-page="./Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i> Back to List
            </a>
        </div>

        <div class="card shadow-sm">
            <div class="card-body p-4">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row mb-3">
                        <div class="col-md-12">
                            <label asp-for="Project.Title" class="form-label fw-bold"></label>
                            <input asp-for="Project.Title" class="form-control" placeholder="Enter project title" />
                            <span asp-validation-for="Project.Title" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-12">
                            <label asp-for="Project.Description" class="form-label fw-bold"></label>
                            <textarea asp-for="Project.Description" class="form-control" rows="3" placeholder="Enter project description"></textarea>
                            <span asp-validation-for="Project.Description" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="Project.CustomerId" class="form-label fw-bold">Customer</label>
                            <select asp-for="Project.CustomerId" class="form-select" asp-items="Model.CustomerList">
                                <option value="">-- Select Customer (Optional) --</option>
                            </select>
                            <span asp-validation-for="Project.CustomerId" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Project.Status" class="form-label fw-bold"></label>
                            <select asp-for="Project.Status" class="form-select" asp-items="Html.GetEnumSelectList<ProjectStatus>()">
                            </select>
                            <span asp-validation-for="Project.Status" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label asp-for="Project.EstimatedValue" class="form-label fw-bold">Estimated Value</label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input asp-for="Project.EstimatedValue" class="form-control" type="number" step="0.01" />
                            </div>
                            <span asp-validation-for="Project.EstimatedValue" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Project.StartDate" class="form-label fw-bold">Start Date</label>
                            <input asp-for="Project.StartDate" class="form-control" type="date" />
                            <span asp-validation-for="Project.StartDate" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Project.EndDate" class="form-label fw-bold">End Date</label>
                            <input asp-for="Project.EndDate" class="form-control" type="date" />
                            <span asp-validation-for="Project.EndDate" class="text-danger"></span>
                        </div>
                    </div>

                    <hr class="my-4" />

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                        <button type="submit" class="btn btn-primary px-5">
                            <i class="bi bi-check-circle me-1"></i> Create Project
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
