@page
@model SaasAsaasApp.Pages.Account.AccessDeniedModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Access Denied";
}

<div class="misc-wrapper text-center">
    <h2 class="mb-2 mx-2">You are not authorized! 🔐</h2>
    <p class="mb-4 mx-2">You don't have permission to access this page. Please contact your administrator or check your subscription status.</p>
    <a asp-page="/Index" class="btn btn-primary">Back to home</a>
    <div class="mt-5">
        <img src="~/assets/img/illustrations/page-misc-error-light.png" alt="page-misc-error-light" width="500" class="img-fluid" />
    </div>
</div>
