@page
@model SaasAsaasApp.Pages.Billing.IndexModel
@{
    ViewData["Title"] = "Billing & Plans";
}

<h4 class="fw-bold py-3 mb-4">
    <span class="text-muted fw-light">Account Settings /</span> Billing & Plans
</h4>

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    var alertClass = Model.StatusMessage.StartsWith("Error") ? "alert-danger" : "alert-success";
    <div class="alert @alertClass alert-dismissible fade show" role="alert">
        @Model.StatusMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row">
    <div class="col-md-12">
        <div class="nav-align-top mb-4">
            <ul class="nav nav-pills mb-3" role="tablist">
                <li class="nav-item">
                    <button type="button" class="nav-link active" role="tab" data-bs-toggle="tab" data-bs-target="#navs-pills-top-plan" aria-controls="navs-pills-top-plan" aria-selected="true">
                        <i class="tf-icons bx bx-star me-1"></i> Current Plan
                    </button>
                </li>
                <li class="nav-item">
                    <button type="button" class="nav-link" role="tab" data-bs-toggle="tab" data-bs-target="#navs-pills-top-history" aria-controls="navs-pills-top-history" aria-selected="false">
                        <i class="tf-icons bx bx-history me-1"></i> Payment History
                    </button>
                </li>
            </ul>
            <div class="tab-content">
                <!-- Subscription Plan Tab -->
                <div class="tab-pane fade show active" id="navs-pills-top-plan" role="tabpanel">
                    <div class="row mb-4">
                        <div class="col-md-6 mb-4 mb-md-0">
                            <div class="card border border-primary h-100">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div class="card-title">
                                            <h5 class="text-primary mb-1">Current Plan: @Model.CurrentPlan.DisplayName</h5>
                                            <p class="text-muted small">Your active subscription details</p>
                                        </div>
                                        <span class="badge bg-label-primary">Active</span>
                                    </div>
                                    <div class="d-flex align-items-center mb-3">
                                        <h2 class="display-5 fw-bold mb-0 text-primary">@Model.CurrentPlan.Price.ToString("C")</h2>
                                        <sub class="text-muted ms-1">/ @Model.CurrentPlan.BillingCycle</sub>
                                    </div>
                                    <ul class="list-unstyled mb-0">
                                        <li class="mb-2 d-flex align-items-center"><i class="bx bx-check text-primary me-2"></i> <span>Up to @Model.CurrentPlan.MaxUsers Users</span></li>
                                        <li class="mb-2 d-flex align-items-center"><i class="bx bx-check text-primary me-2"></i> <span>Up to @Model.CurrentPlan.MaxProjects Projects</span></li>
                                        <li class="d-flex align-items-center"><i class="bx bx-check text-primary me-2"></i> <span>Premium Support</span></li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card h-100 shadow-none border">
                                <div class="card-header border-bottom">
                                    <h5 class="mb-0">Change Your Plan</h5>
                                </div>
                                <div class="card-body pt-3">
                                    @if (!Model.CanChangePlan)
                                    {
                                        <div class="alert alert-warning d-flex align-items-center mb-3" role="alert">
                                            <i class="bx bx-error me-2"></i>
                                            <div>
                                                Plan changes are restricted. Please pay pending invoices.
                                            </div>
                                        </div>
                                    }
                                    <div class="list-group">
                                        @foreach (var plan in Model.AvailablePlans)
                                        {
                                            var isCurrent = plan.Id == Model.CurrentPlan.Id;
                                            <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-center @(isCurrent ? "bg-lighter border-primary" : "")">
                                                <div>
                                                    <h6 class="mb-0 fw-bold">@plan.DisplayName</h6>
                                                    <small class="text-muted">@plan.MaxUsers Users • @plan.MaxProjects Projects</small>
                                                    <div class="text-primary fw-semibold mt-1">@plan.Price.ToString("C") <span class="text-muted fw-normal small">/ @plan.BillingCycle</span></div>
                                                </div>
                                                <div>
                                                    @if (isCurrent)
                                                    {
                                                        <span class="badge bg-label-secondary">Current</span>
                                                    }
                                                    else
                                                    {
                                                        <form method="post" asp-page-handler="ChangePlan" asp-route-planId="@plan.Id">
                                                            <button type="submit" class="btn btn-sm btn-outline-primary" @(Model.CanChangePlan ? "" : "disabled")>
                                                                @(plan.Price > Model.CurrentPlan.Price ? "Upgrade" : "Downgrade")
                                                            </button>
                                                        </form>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Invoice History Tab -->
                <div class="tab-pane fade" id="navs-pills-top-history" role="tabpanel">
                    @if (Model.IsApiError)
                    {
                        <div class="text-center py-5">
                            <i class="bx bx-error-circle text-danger display-1 mb-3"></i>
                            <h5>System temporarily unavailable</h5>
                            <p class="text-muted">We are unable to retrieve your payment history. Please try again later.</p>
                        </div>
                    }
                    else if (Model.PaymentHistory == null || !Model.PaymentHistory.Data.Any())
                    {
                        <div class="text-center py-5">
                            <i class="bx bx-receipt text-muted display-1 mb-3"></i>
                            <p class="text-muted">No payment history found.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive text-nowrap">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Date</th>
                                        <th>Amount</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody class="table-border-bottom-0">
                                    @foreach (var payment in Model.PaymentHistory.Data.OrderByDescending(p => p.DueDate))
                                    {
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="avatar avatar-sm me-3">
                                                        <span class="avatar-initial rounded-circle bg-label-secondary"><i class="bx bx-calendar"></i></span>
                                                    </div>
                                                    <span>@DateTime.Parse(payment.DueDate).ToString("MMM dd, yyyy")</span>
                                                </div>
                                            </td>
                                            <td><strong>@payment.Value.ToString("C")</strong></td>
                                            <td>
                                                @switch (payment.Status)
                                                {
                                                    case "RECEIVED":
                                                    case "CONFIRMED":
                                                    case "RECEIVED_IN_CASH":
                                                        <span class="badge bg-label-success"><i class="bx bx-check-circle bx-xs me-1"></i> Paid</span>
                                                        break;
                                                    case "PENDING":
                                                        <span class="badge bg-label-warning"><i class="bx bx-time-five bx-xs me-1"></i> Pending</span>
                                                        break;
                                                    case "OVERDUE":
                                                        <span class="badge bg-label-danger"><i class="bx bx-x-circle bx-xs me-1"></i> Overdue</span>
                                                        break;
                                                    default:
                                                        <span class="badge bg-label-secondary">@payment.Status</span>
                                                        break;
                                                }
                                            </td>
                                            <td>
                                                <div class="d-flex">
                                                    @if (!string.IsNullOrEmpty(payment.InvoiceUrl))
                                                    {
                                                        <a href="@payment.InvoiceUrl" target="_blank" class="btn btn-icon btn-outline-secondary btn-sm me-2" title="Download Invoice">
                                                            <i class="bx bx-download"></i>
                                                        </a>
                                                    }
                                                    @if (!string.IsNullOrEmpty(payment.BankSlipUrl))
                                                    {
                                                        <a href="@payment.BankSlipUrl" target="_blank" class="btn btn-icon btn-outline-primary btn-sm" title="Bank Slip">
                                                            <i class="bx bx-file"></i>
                                                        </a>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
