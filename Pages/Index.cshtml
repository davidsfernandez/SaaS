@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
}

@if (!isAuthenticated)
{
    <div class="text-center py-5">
        <h1 class="display-4 fw-bold">Welcome to SaasAsaas</h1>
        <p class="lead">The ultimate platform to manage your business and payments with ease.</p>
        <div class="mt-4">
            <a asp-page="/Account/Register" class="btn btn-primary btn-lg px-4 me-md-2">Get Started</a>
            <a asp-page="/Account/Login" class="btn btn-outline-secondary btn-lg px-4">Sign In</a>
        </div>
    </div>
}
else
{
    <div class="container-fluid">
        <div class="row mb-4">
            <div class="col">
                <h2 class="h3 mb-0 text-gray-800">Dashboard</h2>
                <p class="text-muted">Welcome back, <strong>@Model.Metrics.TenantName</strong></p>
            </div>
            <div class="col-auto">
                <span class="badge @(Model.Metrics.SubscriptionStatus == "Active" ? "bg-success" : "bg-warning") p-2">
                    <i class="bi bi-shield-check me-1"></i> @Model.Metrics.SubscriptionStatus Subscription
                </span>
            </div>
        </div>

        <!-- Metrics Cards -->
        <div class="row">
            <!-- Total Customers Card -->
            <div class="col-xl-3 col-md-6 mb-4">
                <div class="card border-left-primary shadow h-100 py-2 border-0 border-start border-primary border-4">
                    <div class="card-body">
                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Customers</div>
                                <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.Metrics.TotalCustomers</div>
                            </div>
                            <div class="col-auto">
                                <i class="bi bi-people-fill fs-2 text-gray-300 text-muted"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Total Projects Card -->
            <div class="col-xl-3 col-md-6 mb-4">
                <div class="card border-left-success shadow h-100 py-2 border-0 border-start border-success border-4">
                    <div class="card-body">
                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Active Projects</div>
                                <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.Metrics.TotalProjects</div>
                            </div>
                            <div class="col-auto">
                                <i class="bi bi-briefcase-fill fs-2 text-gray-300 text-muted"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Estimated Value Card -->
            <div class="col-xl-3 col-md-6 mb-4">
                <div class="card border-left-info shadow h-100 py-2 border-0 border-start border-info border-4">
                    <div class="card-body">
                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-info text-uppercase mb-1">Estimated Value</div>
                                <div class="h5 mb-0 font-weight-bold text-gray-800">R$ @Model.Metrics.TotalEstimatedValue.ToString("N2")</div>
                            </div>
                            <div class="col-auto">
                                <i class="bi bi-currency-dollar fs-2 text-gray-300 text-muted"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Plan Info Card -->
            <div class="col-xl-3 col-md-6 mb-4">
                <div class="card border-left-warning shadow h-100 py-2 border-0 border-start border-warning border-4">
                    <div class="card-body">
                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">Current Plan</div>
                                <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.Metrics.PlanName</div>
                            </div>
                            <div class="col-auto">
                                <i class="bi bi-star-fill fs-2 text-gray-300 text-muted"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mt-4">
            <div class="col-lg-8">
                <div class="card shadow mb-4">
                    <div class="card-header py-3 d-flex justify-content-between align-items-center">
                        <h6 class="m-0 font-weight-bold text-primary">Quick Actions</h6>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <a asp-page="/Customers/Index" class="btn btn-outline-primary w-100 py-3">
                                    <i class="bi bi-person-plus d-block fs-3 mb-2"></i> Manage Customers
                                </a>
                            </div>
                            <div class="col-md-4">
                                <a href="#" class="btn btn-outline-success w-100 py-3 disabled">
                                    <i class="bi bi-folder-plus d-block fs-3 mb-2"></i> New Project
                                </a>
                            </div>
                            <div class="col-md-4">
                                <a asp-page="/Billing/Onboarding" class="btn btn-outline-info w-100 py-3">
                                    <i class="bi bi-credit-card d-block fs-3 mb-2"></i> Billing Center
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-4">
                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary">System Status</h6>
                    </div>
                    <div class="card-body">
                        <p class="small text-muted mb-1">Asaas API Connection</p>
                        <div class="progress mb-3" style="height: 10px;">
                            <div class="progress-bar bg-success" role="progressbar" style="width: 100%"></div>
                        </div>
                        <p class="small text-muted mb-1">Data Storage</p>
                        <div class="progress mb-3" style="height: 10px;">
                            <div class="progress-bar bg-info" role="progressbar" style="width: 25%"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        .border-left-primary { border-left: .25rem solid #4e73df!important; }
        .border-left-success { border-left: .25rem solid #1cc88a!important; }
        .border-left-info { border-left: .25rem solid #36b9cc!important; }
        .border-left-warning { border-left: .25rem solid #f6c23e!important; }
    </style>
}
