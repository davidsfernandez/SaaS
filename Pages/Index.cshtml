@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
}

@if (!isAuthenticated)
{
    <div class="container-xxl flex-grow-1 container-p-y">
        <div class="misc-wrapper text-center">
            <h2 class="mb-2 mx-2 text-primary fw-bold">Elevate your SaaS Business 🚀</h2>
            <p class="mb-4 mx-2">The most secure and robust foundation for your next big idea.</p>
            <div class="mt-4">
                <a asp-page="/Account/Register" class="btn btn-primary btn-lg px-5 me-2">Get Started</a>
                <a asp-page="/Account/Login" class="btn btn-outline-secondary btn-lg px-5">Login</a>
            </div>
            <div class="mt-5">
                <img src="~/assets/img/illustrations/man-with-laptop-light.png" alt="welcome" width="500" class="img-fluid" data-app-light-img="illustrations/man-with-laptop-light.png" />
            </div>
        </div>
    </div>
}
else
{
    <div class="row">
        <div class="col-lg-12 mb-4 order-0">
            <div class="card border-0 shadow-sm">
                <div class="d-flex align-items-end row">
                    <div class="col-sm-7">
                        <div class="card-body">
                            <h5 class="card-title text-primary">Congratulations @Model.Metrics.TenantName! 🎉</h5>
                            <p class="mb-4">
                                Your SaaS is active and performing well. You have <span class="fw-bold">@Model.Metrics.TotalProjects</span> active projects today.
                                Check your latest billing updates.
                            </p>
                            <a asp-page="/Billing/Index" class="btn btn-sm btn-outline-primary">View Badges</a>
                        </div>
                    </div>
                    <div class="col-sm-5 text-center text-sm-start">
                        <div class="card-body pb-0 px-0 px-md-4">
                            <img src="~/assets/img/illustrations/man-with-laptop-light.png" height="140" alt="View Badge User" data-app-light-img="illustrations/man-with-laptop-light.png" />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Metrics Row -->
        <div class="col-lg-12 col-md-12 order-1">
            <div class="row">
                <div class="col-lg-3 col-md-6 col-6 mb-4">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-body text-center">
                            <div class="avatar flex-shrink-0 mx-auto mb-3">
                                <span class="avatar-initial rounded bg-label-primary p-2"><i class="bx bx-user fs-3"></i></span>
                            </div>
                            <span class="fw-semibold d-block mb-1">Customers</span>
                            <h3 class="card-title mb-2">@Model.Metrics.TotalCustomers</h3>
                            <small class="text-success fw-semibold"><i class="bx bx-up-arrow-alt"></i> +12.5%</small>
                        </div>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6 col-6 mb-4">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-body text-center">
                            <div class="avatar flex-shrink-0 mx-auto mb-3">
                                <span class="avatar-initial rounded bg-label-success p-2"><i class="bx bx-briefcase fs-3"></i></span>
                            </div>
                            <span class="fw-semibold d-block mb-1">Active Projects</span>
                            <h3 class="card-title mb-2">@Model.Metrics.TotalProjects</h3>
                            <small class="text-success fw-semibold"><i class="bx bx-up-arrow-alt"></i> +8.2%</small>
                        </div>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6 col-6 mb-4">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-body text-center">
                            <div class="avatar flex-shrink-0 mx-auto mb-3">
                                <span class="avatar-initial rounded bg-label-info p-2"><i class="bx bx-wallet fs-3"></i></span>
                            </div>
                            <span class="fw-semibold d-block mb-1">Estimated Value</span>
                            <h3 class="card-title mb-2">R$ @Model.Metrics.TotalEstimatedValue.ToString("N0")</h3>
                            <small class="text-info fw-semibold"><i class="bx bx-trending-up"></i> High Potential</small>
                        </div>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6 col-6 mb-4">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-body text-center">
                            <div class="avatar flex-shrink-0 mx-auto mb-3">
                                <span class="avatar-initial rounded bg-label-warning p-2"><i class="bx bx-star fs-3"></i></span>
                            </div>
                            <span class="fw-semibold d-block mb-1">Plan</span>
                            <h3 class="card-title mb-2">@Model.Metrics.PlanName</h3>
                            <span class="badge bg-label-warning rounded-pill">@Model.Metrics.SubscriptionStatus</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row">
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-header d-flex align-items-center justify-content-between pb-0">
                    <div class="card-title mb-0">
                        <h5 class="m-0 me-2">System Performance</h5>
                        <small class="text-muted">Real-time infrastructure health</small>
                    </div>
                </div>
                <div class="card-body mt-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="d-flex flex-column align-items-start gap-1">
                            <h6 class="mb-0">API Connection</h6>
                            <small class="text-muted">Asaas Gateway</small>
                        </div>
                        <div class="user-progress">
                            <span class="badge bg-label-success">Stable</span>
                        </div>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="d-flex flex-column align-items-start gap-1">
                            <h6 class="mb-0">Database</h6>
                            <small class="text-muted">PostgreSQL 17</small>
                        </div>
                        <div class="user-progress">
                            <span class="badge bg-label-primary">Optimized</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-8 mb-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <h5 class="card-title m-0 me-2">Quick Access</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-sm-4">
                            <a asp-page="/Customers/Index" class="btn btn-outline-primary w-100 py-3">
                                <i class="bx bx-group d-block fs-3 mb-1"></i> Customers
                            </a>
                        </div>
                        <div class="col-sm-4">
                            <a asp-page="/Projects/Index" class="btn btn-outline-success w-100 py-3">
                                <i class="bx bx-collection d-block fs-3 mb-1"></i> Projects
                            </a>
                        </div>
                        <div class="col-sm-4">
                            <a asp-page="/Billing/Index" class="btn btn-outline-info w-100 py-3">
                                <i class="bx bx-credit-card d-block fs-3 mb-1"></i> Billing
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
